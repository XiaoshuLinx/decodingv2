import os
import numpy as np
import mne
import matplotlib.pyplot as plt
import pandas as pd
from mne.stats import permutation_cluster_1samp_test
from mne.channels import find_ch_adjacency
from mne.stats import spatio_temporal_cluster_1samp_test

# ---------------------- 用户设置 ----------------------
freq = 'alpha'
data_original = 'sensor'

per_subj_dir = f"/nashome2/linx/Desktop/mindeye/ml_data/time_resolved_mvpa_{freq}_{data_original}_coef_topomap/per_subject"
save_dir = f"/nashome2/linx/Desktop/mindeye/ml_data/time_resolved_mvpa_{freq}_{data_original}_coef_topomap/cluster_dual_topomap"
os.makedirs(save_dir, exist_ok=True)

raw_fif = "/projects/mindeye/MRI/wiica/04_ica_di_raw.fif"

# ---------------------- 加载 info ----------------------
raw = mne.io.read_raw_fif(raw_fif, preload=False)
picks = mne.pick_types(raw.info, meg='grad')
info = mne.pick_info(raw.info, picks)
ch_names = info['ch_names']

# ---------------------- 时间 ----------------------
tmin, tmax = -1500, 0
n_times = 376
times = np.linspace(tmin, tmax, n_times)

# ---------------------- 加载数据 ----------------------
subject_files = sorted([f for f in os.listdir(per_subj_dir) if f.endswith('patterns_full.npy')])
all_subject_patterns = []
for f in subject_files:
    p = np.load(os.path.join(per_subj_dir, f))  # (n_channels, n_times)
    assert p.shape[0] == len(ch_names)
    all_subject_patterns.append(p)

X = np.stack(all_subject_patterns, axis=0)  # (subjects, channels, times)
X = np.transpose(X, (0, 2, 1))  # -> (subjects, times, channels)

# ---------------------- baseline correction ----------------------
baseline_win = (-1500, -1000)
analysis_win = (-1000, 0)
baseline_inds = np.where((times >= baseline_win[0]) & (times <= baseline_win[1]))[0]
analysis_inds = np.where((times >= analysis_win[0]) & (times <= analysis_win[1]))[0]

baseline_mean = X[:, baseline_inds, :].mean(axis=1, keepdims=True)
X_baseline_corrected = X.copy()
X_baseline_corrected[:, analysis_inds, :] -= baseline_mean

X_analysis = X_baseline_corrected[:, analysis_inds, :]  # (subjects, times_in_window, channels)

# ---------------------- adjacency ----------------------
adjacency, _ = find_ch_adjacency(info, ch_type='grad')

# ---------------------- cluster permutation ----------------------

T_obs, clusters, cluster_p_values, H0 = spatio_temporal_cluster_1samp_test(
    X_analysis,
    adjacency=adjacency,
    n_permutations=1000,
    threshold=None,
    tail=0,
    n_jobs=1,
    buffer_size=None,
    out_type='mask'
)
# ---------------------- 找显著 cluster ----------------------
alpha = 0.05
sig_clusters = np.where(cluster_p_values < alpha)[0]

excel_records = []

for i_clu, clu_idx in enumerate(sig_clusters):
    mask = clusters[clu_idx]  # (times_in_window, channels)
    time_inds = np.where(mask.any(axis=1))[0]
    t_start, t_end = times[analysis_inds][time_inds[0]], times[analysis_inds][time_inds[-1]]
    sensor_mask = mask[time_inds].any(axis=0)

    # --- T_obs topomap ---
    t_map = T_obs[time_inds, :].mean(axis=0)
    t_map_plot = t_map.copy()
    t_map_plot[~sensor_mask] = 0
    t_map_centered = t_map_plot - np.mean(t_map_plot)
    vmax_t = np.max(np.abs(t_map_centered))
    #vmax_t = np.max(t_map_centered)
    #vmin_t = np.min(t_map_centered)

  

    # --- Pattern / effect size topomap ---
    pattern_map = X_analysis[:, time_inds, :].mean(axis=(0,1))
    pattern_map_plot = pattern_map.copy()
    pattern_map_plot[~sensor_mask] =  0
    pattern_map_centered = pattern_map_plot - np.mean(pattern_map_plot)
    vmax_pattern = np.max(np.abs(pattern_map_centered))

    # --- 绘图 ---
    fig, axes = plt.subplots(1, 2, figsize=(10,5))
    mne.viz.plot_topomap(
        t_map_centered, info, axes=axes[0], cmap='RdBu_r', vlim=(-vmax_t, vmax_t), show=False
    )
    axes[0].set_title(f"T_obs {t_start:.0f}-{t_end:.0f} ms\np={cluster_p_values[clu_idx]:.3f}", fontsize=20,pad=-200)

    mne.viz.plot_topomap(
        pattern_map_centered, info, axes=axes[1], cmap='RdBu_r', vlim=(-vmax_pattern, vmax_pattern), show=False
    )
    axes[1].set_title(f"Pattern / Effect size\n{t_start:.0f}-{t_end:.0f} ms", fontsize=20,pad=-200)

    fname = os.path.join(save_dir, f"cluster_{i_clu}_{int(t_start)}_{int(t_end)}ms_dual.png")
    plt.savefig(fname, dpi=300)
    plt.close()
    print(f"Saved: {fname}")

    # --- Excel 记录 ---
    for ch_idx, ch_name in enumerate(ch_names):
        excel_records.append({
            "Cluster": i_clu,
            "p_value": cluster_p_values[clu_idx],
            "t_start_ms": t_start,
            "t_end_ms": t_end,
            "Channel": ch_name,
            "Is_significant": bool(sensor_mask[ch_idx]),
            "T_value": t_map[ch_idx],
            "Pattern_value": pattern_map[ch_idx]
        })

# 保存 Excel
df = pd.DataFrame(excel_records)
excel_path = os.path.join(save_dir, "significant_clusters_dual_topomap.xlsx")
df.to_excel(excel_path, index=False)
print(f"✅ Done! Excel saved to {excel_path}")
