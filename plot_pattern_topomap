#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Group-level full-pattern topomap (指定时间窗 + 自动中心化)
For patterns shape: (n_features, n_times)
Author: Linx + ChatGPT
Date: 2026-03-20
"""
import os
import numpy as np
import mne
import matplotlib.pyplot as plt

# ---------------------- 用户设置 ----------------------
freq = 'epoch'
data_original = 'sensor'
per_subj_dir = f"/nashome2/linx/Desktop/mindeye/ml_data/time_resolved_mvpa_{freq}_{data_original}_coef_topomap/per_subject"
save_dir = f"/nashome2/linx/Desktop/mindeye/ml_data/time_resolved_mvpa_{freq}_{data_original}_coef_topomap/pattern"

raw_fif = "/projects/mindeye/MRI/wiica/04_ica_di_raw.fif"  # 任意一个subject的raw info即可
os.makedirs(save_dir, exist_ok=True)

# ---------------------- 加载 raw info ----------------------
print("Loading raw info from:", raw_fif)
raw = mne.io.read_raw_fif(raw_fif, preload=False)
raw.pick_types(meg=True, eeg=False, eog=False, stim=False)
raw.pick_types(meg='grad')
info = raw.info
n_features = len(info['ch_names'])

# ---------------------- 时间参数 ----------------------
tmin = -1500
tmax = 0
n_times = 376
times = np.linspace(tmin, tmax, n_times)

# ---------------------- 加载所有 subject full patterns ----------------------
subject_files = sorted([f for f in os.listdir(per_subj_dir) if f.endswith('patterns_full.npy')])
all_subject_patterns = []
for f in subject_files:
    p = np.load(os.path.join(per_subj_dir, f))  # shape (n_features, n_times)
    assert p.shape[0] == n_features, f"{f} feature number mismatch"
    all_subject_patterns.append(p)
all_subject_patterns = np.stack(all_subject_patterns, axis=0)  # shape (n_subjects, n_features, n_times)
print(f"Loaded patterns: {all_subject_patterns.shape}")

# ---------------------- 计算 group mean ----------------------
group_mean_patterns = all_subject_patterns.mean(axis=0)  # shape (n_features, n_times)

# ---------------------- 指定时间窗 topomap ----------------------
time_windows = [(-1500,-1400), (-1400,-1300), (-1300,-1200), (-1200,-1100), 
                (-1100,-1000), (-1000,-900), (-900,-800), (-800,-700),
                (-700,-600), (-600,-500), (-500,-400), (-400,-300),
                (-300,-200), (-200,-100), (-100,0)]  # 可以自定义
time_windows = [(-1500,-1250), (-1250,-1000), (-1000,-750), (-750,-500), 
              
                (-500,-250), (-250,0),]  
fig_list = []
for t_start, t_end in time_windows:
    # 找到对应 index
    idx_start = np.argmin(np.abs(times - t_start))
    idx_end = np.argmin(np.abs(times - t_end)) + 1  # +1 包含最后一个点

    # 对时间窗平均
    pattern_window = group_mean_patterns[:, idx_start:idx_end].mean(axis=1)

    # 中心化 pattern，保证红蓝对称
    pattern_window_centered = pattern_window - np.mean(pattern_window)
    max_abs = np.max(np.abs(pattern_window_centered))
    print(np.min(pattern_window_centered), np.max(pattern_window_centered))


    # 绘制 topomap
    fig, ax = plt.subplots()
    mne.viz.plot_topomap(pattern_window_centered, info, axes=ax, show=False,
                         cmap='RdBu_r', vlim=(-max_abs, max_abs))
    ax.set_title(f"{t_start}-{t_end} ms", fontsize=20,pad=-200)


    # 保存图片
    fname_fig = os.path.join(save_dir, f"group_topomap_{t_start}_{t_end}ms.png")
    plt.savefig(fname_fig, dpi=300)
    plt.close()
    print(f"Saved topomap -> {fname_fig}")
    fig_list.append(pattern_window_centered)

print("\n✅ All group-level topomaps saved in:", save_dir)


# ---------------------- 合并大图 ----------------------
n_cols = len(time_windows)
fig, axes = plt.subplots(1, n_cols, figsize=(3*n_cols, 4))  # 每列一个时间窗
if n_cols == 1:
    axes = [axes]

for ax, pattern_window_centered, (t_start, t_end) in zip(axes, fig_list, time_windows):
    max_abs = np.max(np.abs(pattern_window_centered))
    mne.viz.plot_topomap(pattern_window_centered, info, axes=ax, show=False,
                         cmap='RdBu_r', vlim=(-max_abs, max_abs))
    ax.set_title(f"{t_start}-{t_end} ms", fontsize=20,pad=-200)

plt.tight_layout()
fname_big = os.path.join(save_dir, "group_topomap_all_windows.png")
plt.savefig(fname_big, dpi=300)
plt.close()
print(f"\n✅ Combined topomap saved -> {fname_big}")
